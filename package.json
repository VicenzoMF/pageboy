{
  "name": "pageboy",
  "version": "0.2.0",
  "description": "Turn any web article into a queryable MCP server. SQLite + FTS5 + optional local embeddings.",
  "type": "module",
  "bin": {
    "pageboy": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "node dist/cli.js serve"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "jsdom": "^25.0.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
